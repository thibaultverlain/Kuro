<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notification Kuro</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #080610; margin: 0; padding: 0; color: #f0ecff; }
        .wrapper { max-width: 560px; margin: 40px auto; }
        .header { background: linear-gradient(135deg, #7c3aff, #b14cff); border-radius: 14px 14px 0 0; padding: 28px 32px; text-align: center; }
        .header h1 { margin: 0; font-size: 22px; font-weight: 800; color: white; letter-spacing: -0.3px; }
        .header p { margin: 6px 0 0; font-size: 13px; color: rgba(255,255,255,0.7); }
        .body { background: #141220; border: 1px solid rgba(124,58,255,0.2); border-top: none; border-radius: 0 0 14px 14px; padding: 28px 32px; }
        .greeting { font-size: 15px; color: #f0ecff; margin-bottom: 16px; }
        .message-box { background: rgba(124,58,255,0.1); border: 1px solid rgba(124,58,255,0.25); border-radius: 10px; padding: 16px 20px; font-size: 14px; color: #c4bfec; line-height: 1.6; margin-bottom: 20px; }
        .btn { display: inline-block; padding: 12px 24px; background: linear-gradient(135deg, #7c3aff, #b14cff); color: white; text-decoration: none; border-radius: 10px; font-size: 14px; font-weight: 700; margin-bottom: 24px; }
        .footer { font-size: 12px; color: #5e5a7a; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 16px; line-height: 1.6; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
        .badge-assigned { background: rgba(6,214,255,0.15); color: #06d6ff; }
        .badge-created  { background: rgba(0,229,160,0.15); color: #00e5a0; }
        .badge-updated  { background: rgba(245,158,11,0.15); color: #f59e0b; }
        .badge-deleted  { background: rgba(255,59,107,0.15); color: #ff3b6b; }
    </style>
</head>
<body>
<div class="wrapper">
    <div class="header">
        <h1>✦ Kuro</h1>
        <p>Gestionnaire de tâches collaboratif</p>
    </div>

    <div class="body">
        <p class="greeting">Bonjour {{ user.name ?: user.email }},</p>

        {% if type == 'task_assigned' %}
            <span class="badge badge-assigned">📌 Tâche assignée</span>
        {% elseif type == 'task_created' %}
            <span class="badge badge-created">🆕 Tâche créée</span>
        {% elseif type == 'task_updated' %}
            <span class="badge badge-updated">✏️ Tâche modifiée</span>
        {% elseif type == 'task_deleted' %}
            <span class="badge badge-deleted">🗑️ Tâche supprimée</span>
        {% endif %}

        <div class="message-box">{{ message }}</div>

        {% if link %}
            <a href="{{ link }}" class="btn">Voir la tâche →</a>
        {% endif %}

        <div class="footer">
            Vous recevez cet email car vous êtes membre d'un projet Kuro.<br>
            Pour gérer vos préférences de notification, connectez-vous à l'application.
        </div>
    </div>
</div>
</body>
</html>
