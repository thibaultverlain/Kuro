{% extends 'base_front.html.twig' %}

{% block body %}

{# =========================================================
   PAGE HEADER
========================================================= #}
<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Dashboard</h1>
            <p class="header-subtitle">Bienvenue, {{ app.user.name }} — voici un aperçu de vos projets</p>
        </div>
    </div>
</div>

{# =========================================================
   STATS RAPIDES
========================================================= #}
{% set totalProjects = 0 %}
{% set totalTasks = 0 %}
{% set totalDone = 0 %}
{% set totalLate = 0 %}

{% for project in projects %}
    {% if project.users.contains(app.user) %}
        {% set totalProjects = totalProjects + 1 %}
    {% endif %}
{% endfor %}

{% for task in tasks %}
    {% if task.project.users.contains(app.user) %}
        {% set totalTasks = totalTasks + 1 %}
        {% if task.status.name == 'Terminée' %}{% set totalDone = totalDone + 1 %}{% endif %}
        {% if task.isLate %}{% set totalLate = totalLate + 1 %}{% endif %}
    {% endif %}
{% endfor %}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="dashboard-block" style="display:flex; align-items:center; gap:14px;">
            <div style="width:40px;height:40px;border-radius:var(--r-md);background:var(--teal-soft);display:flex;align-items:center;justify-content:center;color:var(--teal);font-size:16px;flex-shrink:0;">
                <i class="fa-solid fa-folder-open"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--text-primary);line-height:1;">{{ totalProjects }}</div>
                <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;font-weight:600;margin-top:3px;">Projets</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dashboard-block" style="display:flex; align-items:center; gap:14px;">
            <div style="width:40px;height:40px;border-radius:var(--r-md);background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;color:var(--amber);font-size:16px;flex-shrink:0;">
                <i class="fa-solid fa-list-check"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--text-primary);line-height:1;">{{ totalTasks }}</div>
                <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;font-weight:600;margin-top:3px;">Tâches</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dashboard-block" style="display:flex; align-items:center; gap:14px;">
            <div style="width:40px;height:40px;border-radius:var(--r-md);background:rgba(16,185,129,0.1);display:flex;align-items:center;justify-content:center;color:var(--emerald);font-size:16px;flex-shrink:0;">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--text-primary);line-height:1;">{{ totalDone }}</div>
                <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;font-weight:600;margin-top:3px;">Terminées</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dashboard-block" style="display:flex; align-items:center; gap:14px;">
            <div style="width:40px;height:40px;border-radius:var(--r-md);background:rgba(239,68,68,0.1);display:flex;align-items:center;justify-content:center;color:var(--red);font-size:16px;flex-shrink:0;">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--text-primary);line-height:1;">{{ totalLate }}</div>
                <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;font-weight:600;margin-top:3px;">En retard</div>
            </div>
        </div>
    </div>
</div>

{# =========================================================
   MES PROJETS + TÂCHES PAR USER
========================================================= #}
<div class="row g-3 mb-4">

    {# Projets #}
    <div class="col-md-5">
        <div class="dashboard-block h-100">
            <h2 class="block-title">Mes projets</h2>
            <div class="projects-grid">
                {% for project in projects %}
                    {% if project.users.contains(app.user) %}
                        <a href="{{ path('front_project_show', {id: project.id}) }}" class="project-card">
                            <div class="card-header">
                                <span class="project-title">{{ project.name }}</span>
                                <span class="project-date">
                                    <i class="fa-regular fa-calendar" style="font-size:10px;"></i>
                                    {{ project.createdAt|date('d/m/Y') }}
                                </span>
                            </div>
                            {% if project.description %}
                                <p class="project-desc">{{ project.description|slice(0, 80) }}{% if project.description|length > 80 %}…{% endif %}</p>
                            {% endif %}
                            <div style="display:flex;align-items:center;gap:6px;">
                                <span class="meta-pill">
                                    <i class="fa-solid fa-list-check"></i>
                                    {{ project.tasks|length }} tâche{{ project.tasks|length > 1 ? 's' : '' }}
                                </span>
                                <span class="meta-pill">
                                    <i class="fa-solid fa-users"></i>
                                    {{ project.users|length }} membre{{ project.users|length > 1 ? 's' : '' }}
                                </span>
                            </div>
                        </a>
                    {% endif %}
                {% else %}
                    <p style="color:var(--text-muted);font-size:13px;">Aucun projet enregistré.</p>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Tâches par utilisateur #}
    <div class="col-md-7">
        <div class="dashboard-block h-100">
            <h2 class="block-title">Tâches par utilisateur</h2>
            <div class="table-responsive">
                <table class="table user-task-table">
                    <thead>
                        <tr>
                            <th>Utilisateur</th>
                            <th>En cours</th>
                            <th>À faire</th>
                            <th>Terminées</th>
                            <th>En retard</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            {% set enCours = 0 %}
                            {% set enAttente = 0 %}
                            {% set terminee = 0 %}
                            {% set enRetard = 0 %}

                            {% for task in tasks %}
                                {% if task.project.users.contains(app.user) and user.tasks.contains(task) %}
                                    {% set status = task.status.name %}
                                    {% if status == 'En cours' %}
                                        {% set enCours = enCours + 1 %}
                                    {% elseif status == 'À faire' %}
                                        {% set enAttente = enAttente + 1 %}
                                    {% elseif status == 'Terminée' %}
                                        {% set terminee = terminee + 1 %}
                                    {% elseif status == 'En retard' %}
                                        {% set enRetard = enRetard + 1 %}
                                    {% endif %}
                                {% endif %}
                            {% endfor %}

                            {% set total = enCours + enAttente + terminee + enRetard %}

                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <div style="width:28px;height:28px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;color:var(--bg-root);font-size:11px;font-weight:700;flex-shrink:0;">
                                            {{ user.name|slice(0,1)|upper }}
                                        </div>
                                        <span style="font-weight:600;font-size:13px;color:var(--text-primary);">{{ user.name }}</span>
                                    </div>
                                </td>
                                <td><span class="badge badge-en-cours">{{ enCours }}</span></td>
                                <td><span class="badge badge-en-attente">{{ enAttente }}</span></td>
                                <td><span class="badge badge-terminee">{{ terminee }}</span></td>
                                <td><span class="badge badge-en-retard">{{ enRetard }}</span></td>
                                <td><span style="font-weight:700;color:var(--text-primary);">{{ total }}</span></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="6" style="color:var(--text-muted);font-size:13px;">Aucun utilisateur trouvé.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{# =========================================================
   GRAPHIQUE
========================================================= #}
<div class="chart-block-modern mb-4">
    <h2 class="block-title">Suivi des tâches par projet</h2>
    <canvas id="tasksByProjectChart" height="100"></canvas>
</div>

{% endblock %}

{% block javascripts %}
<script>
const projectsData = {{ projectsData|json_encode|raw }};
const labels = Object.keys(projectsData);

const enCours  = labels.map(p => projectsData[p]['En cours']  ?? 0);
const terminee = labels.map(p => projectsData[p]['Terminée']  ?? 0);
const enRetard = labels.map(p => projectsData[p]['En retard'] ?? 0);
const enAttente= labels.map(p => projectsData[p]['En attente']?? 0);

const ctx = document.getElementById('tasksByProjectChart').getContext('2d');

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: labels,
        datasets: [
            { label: 'En cours',  data: enCours,   backgroundColor: 'rgba(45,212,191,0.7)',  borderRadius: 6 },
            { label: 'Terminée',  data: terminee,  backgroundColor: 'rgba(16,185,129,0.7)',  borderRadius: 6 },
            { label: 'En retard', data: enRetard,  backgroundColor: 'rgba(239,68,68,0.7)',   borderRadius: 6 },
            { label: 'À faire',   data: enAttente, backgroundColor: 'rgba(245,158,11,0.7)',  borderRadius: 6 }
        ]
    },
    options: {
        responsive: true,
        plugins: {
            legend: {
                labels: {
                    color: '#9898b0',
                    font: { family: 'Inter', size: 12 },
                    boxWidth: 12,
                    boxHeight: 12
                }
            }
        },
        scales: {
            y: {
                min: 0,
                ticks: { stepSize: 1, color: '#9898b0', font: { family: 'Inter', size: 11 } },
                grid: { color: 'rgba(255,255,255,0.05)' },
                border: { color: 'rgba(255,255,255,0.05)' }
            },
            x: {
                ticks: { color: '#9898b0', font: { family: 'Inter', size: 11 } },
                grid: { display: false },
                border: { color: 'rgba(255,255,255,0.05)' }
            }
        }
    }
});
</script>
{% endblock %}
