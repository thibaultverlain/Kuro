{% extends 'base_front.html.twig' %}

{% block title %}Dashboard — Kuro{% endblock %}

{% block body %}

<div class="dashboard-block mb-4">
    <h2 class="block-title">Mes projets</h2>
    <div class="row">
        {% for project in projects %}
            <div class="col-md-4 mb-3">
                <a href="{{ path('front_project_show', {id: project.id}) }}" class="project-card text-decoration-none d-block">
                    <div class="card-header">
                        <h5 class="project-title">{{ project.name }}</h5>
                        <span class="project-date">{{ project.createdAt|date('d/m/Y') }}</span>
                    </div>
                    {% if project.description %}
                        <p class="project-desc">{{ project.description|slice(0, 80) }}{% if project.description|length > 80 %}…{% endif %}</p>
                    {% endif %}
                    <small style="color:var(--text-muted);font-size:11px">
                        {{ project.tasks|length }} tâche{{ project.tasks|length > 1 ? 's' : '' }} ·
                        {{ project.users|length }} membre{{ project.users|length > 1 ? 's' : '' }}
                    </small>
                </a>
            </div>
        {% else %}
            <div class="col-12">
                <p style="color:var(--text-muted)">Aucun projet. <a href="{{ path('front_project_new') }}" style="color:var(--violet-light)">Créer un projet</a></p>
            </div>
        {% endfor %}
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="chart-block-modern">
            <h2 class="block-title">Tâches par projet</h2>
            <canvas id="tasksByProjectChart" height="160"></canvas>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="chart-block-modern">
            <h2 class="block-title">Activité — 7 derniers jours</h2>
            <canvas id="activityChart" height="160"></canvas>
        </div>
    </div>
</div>

<div class="dashboard-block mb-5">
    <h2 class="block-title">Tâches par utilisateur</h2>
    <div class="table-responsive">
        <table class="table user-task-table">
            <thead>
                <tr>
                    <th>Utilisateur</th>
                    {% for sName in statusNames %}
                        <th>{{ sName }}</th>
                    {% endfor %}
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    {% set counts = {} %}
                    {% set total = 0 %}
                    {% for sName in statusNames %}
                        {% set counts = counts|merge({(sName): 0}) %}
                    {% endfor %}

                    {% for task in tasks %}
                        {% if user.tasks.contains(task) %}
                            {% set sName = task.status ? task.status.name : 'Inconnu' %}
                            {% if counts[sName] is defined %}
                                {% set counts = counts|merge({(sName): counts[sName] + 1}) %}
                            {% endif %}
                            {% set total = total + 1 %}
                        {% endif %}
                    {% endfor %}

                    {% if total > 0 %}
                    <tr>
                        <td><strong>{{ user.name ?: user.email }}</strong></td>
                        {% for sName in statusNames %}
                            <td>
                                {% set badgeClass = 'badge-sans-statut' %}
                                {% if sName == 'En cours' %}{% set badgeClass = 'badge-en-cours' %}
                                {% elseif sName == 'Terminée' %}{% set badgeClass = 'badge-terminee' %}
                                {% elseif sName == 'À faire' %}{% set badgeClass = 'badge-en-attente' %}
                                {% elseif sName == 'En révision' %}{% set badgeClass = 'badge-en-cours' %}
                                {% endif %}
                                <span class="badge {{ badgeClass }}">{{ counts[sName] ?? 0 }}</span>
                            </td>
                        {% endfor %}
                        <td><strong>{{ total }}</strong></td>
                    </tr>
                    {% endif %}
                {% else %}
                    <tr><td colspan="{{ statusNames|length + 2 }}" style="color:var(--text-muted)">Aucun utilisateur.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const isDark      = !document.body.classList.contains('light-mode');
    const gridColor   = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
    const tickColor   = isDark ? '#9d98c0' : '#5b5380';
    const legendColor = isDark ? '#9d98c0' : '#5b5380';

    Chart.defaults.font.family = "'DM Sans', system-ui, sans-serif";
    Chart.defaults.font.size   = 12;

    const palette = [
        'rgba(6,214,255,0.65)',
        'rgba(0,229,160,0.65)',
        'rgba(245,158,11,0.65)',
        'rgba(124,58,255,0.65)',
        'rgba(255,59,107,0.65)',
        'rgba(177,76,255,0.65)',
    ];

    // === Graphique 1 : tâches par projet ===
    const projectsData = {{ projectsData|json_encode|raw }};
    const statusNames  = {{ statusNames|json_encode|raw }};
    const pLabels = Object.keys(projectsData);

    if (pLabels.length > 0) {
        new Chart(document.getElementById('tasksByProjectChart'), {
            type: 'bar',
            data: {
                labels: pLabels,
                datasets: statusNames.map((sName, i) => ({
                    label: sName,
                    data: pLabels.map(p => projectsData[p][sName] ?? 0),
                    backgroundColor: palette[i % palette.length],
                    borderRadius: 6,
                }))
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: legendColor, boxWidth: 12 } } },
                scales: {
                    x: { ticks: { color: tickColor }, grid: { color: gridColor } },
                    y: { min: 0, ticks: { stepSize: 1, color: tickColor }, grid: { color: gridColor } }
                }
            }
        });
    }

    // === Graphique 2 : activité 7 jours ===
    const activityData = {{ activityData|json_encode|raw }};

    new Chart(document.getElementById('activityChart'), {
        type: 'line',
        data: {
            labels: activityData.labels,
            datasets: [
                {
                    label: 'Créées',
                    data: activityData.created,
                    borderColor: '#7c3aff',
                    backgroundColor: 'rgba(124,58,255,0.1)',
                    borderWidth: 2,
                    pointBackgroundColor: '#7c3aff',
                    pointRadius: 4,
                    tension: 0.4,
                    fill: true,
                },
                {
                    label: 'Terminées',
                    data: activityData.completed,
                    borderColor: '#00e5a0',
                    backgroundColor: 'rgba(0,229,160,0.1)',
                    borderWidth: 2,
                    pointBackgroundColor: '#00e5a0',
                    pointRadius: 4,
                    tension: 0.4,
                    fill: true,
                }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { labels: { color: legendColor, boxWidth: 12 } } },
            scales: {
                x: { ticks: { color: tickColor }, grid: { color: gridColor } },
                y: { min: 0, ticks: { stepSize: 1, color: tickColor }, grid: { color: gridColor } }
            }
        }
    });
});
</script>
{% endblock %}
