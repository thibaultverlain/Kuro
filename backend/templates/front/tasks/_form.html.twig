{% if task is defined %}
    {% if task.project.users.contains(app.user) %}
        {{ form_start(form, {'attr': {'class': 'task-form needs-validation'}}) }}
            {{ form_widget(form) }}
            <div style="margin-top: 8px;">
                <button type="submit" class="btn-glass">
                    <i class="fa-solid fa-check"></i> {{ button_label|default('Enregistrer') }}
                </button>
            </div>
        {{ form_end(form) }}
    {% else %}
        <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:var(--r-md);padding:12px 16px;color:var(--red);font-size:13px;">
            <i class="fa-solid fa-circle-exclamation me-2"></i> Accès refusé.
        </div>
    {% endif %}
{% else %}
    {% if project.users.contains(app.user) %}
        {{ form_start(form, {'attr': {'class': 'task-form needs-validation'}}) }}
            {{ form_widget(form) }}
            <div style="margin-top: 8px;">
                <button type="submit" class="btn-glass">
                    <i class="fa-solid fa-check"></i> {{ button_label|default('Enregistrer') }}
                </button>
            </div>
        {{ form_end(form) }}
    {% else %}
        <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:var(--r-md);padding:12px 16px;color:var(--red);font-size:13px;">
            <i class="fa-solid fa-circle-exclamation me-2"></i> Accès refusé.
        </div>
    {% endif %}
{% endif %}
