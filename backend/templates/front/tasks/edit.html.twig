{% extends 'base_front.html.twig' %}

{% block title %}Modifier la tâche{% endblock %}

{% block body %}

{% if task.project.users.contains(app.user) %}

{# =========================================================
   PAGE HEADER
========================================================= #}
<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Modifier la tâche</h1>
            <p class="header-subtitle">{{ task.title }}</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            {% if task.project %}
                <a href="{{ path('front_project_show', {'id': task.project.id}) }}" class="btn-glass">
                    <i class="fa-solid fa-folder-open"></i> {{ task.project.name }}
                </a>
            {% endif %}
            <a href="{{ path('front_tasks_by_project', { id: task.project.id }) }}" class="btn-reset">
                <i class="fa-solid fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>
</div>

<div class="row g-3">

    {# Formulaire #}
    <div class="col-md-8">
        <div class="task-card-form">
            <div class="task-card-header">
                <h2 class="task-card-title">
                    <i class="fa-solid fa-pen-to-square"></i>
                    Informations de la tâche
                </h2>
            </div>
            <div class="task-card-body">
                <div class="task-form">
                    {{ form_start(form) }}
                        {{ form_widget(form) }}
                        <div style="margin-top:16px;">
                            <button type="submit" class="btn-glass">
                                <i class="fa-solid fa-check"></i> Enregistrer les modifications
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
            <div class="task-actions-footer">
                {{ include('front/tasks/_delete_form.html.twig', { task: task }) }}
            </div>
        </div>
    </div>

    {# Historique #}
    <div class="col-md-4">
        <div class="dashboard-block">
            <h2 class="block-title">Historique</h2>
            <div class="history-list">
                {% for entry in task.history %}
                    <div style="padding:10px 12px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);margin-bottom:6px;">
                        <div style="font-size:11px;color:var(--teal);font-weight:600;margin-bottom:3px;">
                            <i class="fa-regular fa-clock"></i>
                            {{ entry.updatedAt|date('d/m/Y H:i') }}
                        </div>
                        <div style="font-size:13px;color:var(--text-primary);">
                            {{ entry.changelog }}
                        </div>
                        {% if entry.author %}
                            <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">
                                <i class="fa-solid fa-user"></i>
                                {{ entry.author.name }}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="empty-state-text">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        Aucune modification enregistrée.
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

</div>

{% else %}
<div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:var(--r-md);padding:16px;color:var(--red);font-size:13px;">
    <i class="fa-solid fa-circle-exclamation me-2"></i> Accès refusé.
</div>
{% endif %}

{% endblock %}
