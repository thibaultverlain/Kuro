{% extends 'base_front.html.twig' %}

{% block title %}Détails de la tâche{% endblock %}

{% block body %}

{% if task.project.users.contains(app.user) %}

{# =========================================================
   PAGE HEADER
========================================================= #}
<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">{{ task.title }}</h1>
            {% if task.project %}
                <p class="header-subtitle">
                    <i class="fa-solid fa-folder-open" style="font-size:11px;"></i>
                    {{ task.project.name }}
                </p>
            {% endif %}
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <a href="{{ path('front_tasks_by_project', { id: task.project.id }) }}" class="btn-reset">
                <i class="fa-solid fa-arrow-left"></i> Retour
            </a>
            <a href="{{ path('front_tasks_edit', {'id': task.id}) }}" class="btn-glass">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
            {{ include('front/tasks/_delete_form.html.twig', { task: task, btn_class: 'btn-small' }) }}
        </div>
    </div>
</div>

<div class="row g-3">

    {# =========================================================
       DÉTAILS DE LA TÂCHE
    ========================================================= #}
    <div class="col-md-8">
        <div class="task-card-form">
            <div class="task-card-header">
                <h2 class="task-card-title">
                    <i class="fa-solid fa-circle-info"></i>
                    Détails
                </h2>
            </div>
            <div class="task-card-body">

                {# Description #}
                {% if task.description %}
                    <div style="margin-bottom:20px;">
                        <div class="filter-label" style="margin-bottom:8px;">
                            <i class="fa-solid fa-align-left"></i> Description
                        </div>
                        <p style="color:var(--text-secondary);font-size:13.5px;line-height:1.6;margin:0;">
                            {{ task.description }}
                        </p>
                    </div>
                {% endif %}

                {# Badges statut + priorité #}
                <div class="task-meta" style="margin-bottom:20px;">
                    {% if task.priority %}
                        {% set priorityMap = {
                            'Tres faible': 'tres-faible',
                            'Faible': 'faible',
                            'Modere': 'modere',
                            'Eleve': 'eleve',
                            'Tres eleve': 'tres-eleve'
                        } %}
                        {% set priorityClass = priorityMap[task.priority.name]|default('') %}
                        <span class="priority-badge priority-{{ priorityClass }}">
                            <i class="fa-solid fa-flag"></i>
                            {{ task.priority.name }}
                        </span>
                    {% endif %}

                    {% if task.status %}
                        {% set statusMap = {
                            'En cours':  'en-cours',
                            'Terminée':  'termine',
                            'En retard': 'retard',
                            'À faire':   'en-attente'
                        } %}
                        {% set statusClass = statusMap[task.status.name]|default('') %}
                        <span class="status-badge status-{{ statusClass }}">
                            <i class="fa-solid fa-circle status-icon"></i>
                            {{ task.status.name }}
                        </span>
                    {% endif %}

                    {% if task.dueDate %}
                        <span class="task-date">
                            <i class="fa-regular fa-calendar"></i>
                            {{ task.dueDate|date('d/m/Y') }}
                        </span>
                    {% endif %}
                </div>

                {# Infos supplémentaires #}
                <div style="display:flex;flex-direction:column;gap:8px;">
                    {% if task.createdAt %}
                        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                            <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                                <i class="fa-solid fa-plus" style="color:var(--teal);"></i> Créée le
                            </span>
                            <span style="font-size:13px;color:var(--text-primary);font-weight:500;">
                                {{ task.createdAt|date('d/m/Y') }}
                            </span>
                        </div>
                    {% endif %}

                    {% if task.lastChangedAt %}
                        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                            <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                                <i class="fa-solid fa-pen" style="color:var(--teal);"></i> Modifiée le
                            </span>
                            <span style="font-size:13px;color:var(--text-primary);font-weight:500;">
                                {{ task.lastChangedAt|date('d/m/Y') }}
                            </span>
                        </div>
                    {% endif %}

                    {% if task.project %}
                        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                            <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                                <i class="fa-solid fa-folder-open" style="color:var(--teal);"></i> Projet
                            </span>
                            <a href="{{ path('front_project_show', {'id': task.project.id}) }}"
                               style="font-size:13px;color:var(--teal);font-weight:500;text-decoration:none;">
                                {{ task.project.name }}
                            </a>
                        </div>
                    {% endif %}
                </div>

                {# Assignés #}
                {% if task.users is not empty %}
                    <div style="margin-top:20px;">
                        <div class="filter-label" style="margin-bottom:10px;">
                            <i class="fa-solid fa-users"></i> Assignés
                        </div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            {% for assignee in task.users %}
                                <div style="display:flex;align-items:center;gap:8px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:999px;padding:5px 12px 5px 6px;">
                                    <div style="width:26px;height:26px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;color:var(--bg-root);font-size:11px;font-weight:700;">
                                        {{ assignee.name|slice(0,1)|upper }}
                                    </div>
                                    <span style="font-size:13px;color:var(--text-primary);font-weight:500;">{{ assignee.name }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

            </div>
        </div>
    </div>

    {# =========================================================
       HISTORIQUE
    ========================================================= #}
    <div class="col-md-4">
        <div class="dashboard-block h-100">
            <h2 class="block-title">Historique</h2>
            <div class="history-list">
                {% for entry in task.history %}
                    <div style="padding:10px 12px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);margin-bottom:6px;">
                        <div style="font-size:11px;color:var(--teal);font-weight:600;margin-bottom:3px;">
                            <i class="fa-regular fa-clock"></i>
                            {{ entry.updatedAt|date('d/m/Y H:i') }}
                        </div>
                        <div style="font-size:13px;color:var(--text-primary);">
                            {{ entry.changelog }}
                        </div>
                        {% if entry.author %}
                            <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">
                                <i class="fa-solid fa-user"></i>
                                {{ entry.author.name }}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="empty-state-text">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        Aucune modification enregistrée.
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

</div>

{% else %}
<div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:var(--r-md);padding:16px;color:var(--red);font-size:13px;">
    <i class="fa-solid fa-circle-exclamation me-2"></i> Accès refusé.
</div>
{% endif %}

{% endblock %}
