{% extends 'base_front.html.twig' %}

{% block title %}Détails de la tâche{% endblock %}

{% block body %}

{% if task.project.users.contains(app.user) %}

<div class="container mt-5">

    <div class="task-card">

        <div class="task-header">
            <div class="task-title-section">
                <strong class="task-title">{{ task.title }}</strong>

                {% if task.description %}
                    <small class="task-description">
                        {{ task.description }}
                    </small>
                {% endif %}
            </div>

            {% if task.dueDate %}
                <span class="task-date">
                    <i class="bi bi-calendar-event"></i>
                    {{ task.dueDate|date('d F Y') }}
                </span>
            {% endif %}
        </div>

        <div class="task-meta">

            {% if task.priority %}
                {% set priorityName = task.priority.name %}
                {% set priorityMap = {
                    'Tres faible': 'tres-faible',
                    'Faible': 'faible',
                    'Modere': 'modere',
                    'Eleve': 'eleve',
                    'Tres eleve': 'tres-eleve'
                } %}
                {% set priorityClass = priorityMap[priorityName]|default('') %}

                <span class="priority-badge {{ priorityClass ? 'priority-' ~ priorityClass : '' }}">
                    <i class="bi bi-flag-fill"></i>
                    {{ priorityName }}
                </span>
            {% endif %}

            {% if task.status %}
                {% set statusName = task.status.name %}
                {% set statusMap = {
                    'En cours': 'en-cours',
                    'Terminee': 'termine',
                    'En retard': 'retard',
                    'En attente': 'en-attente'
                } %}
                {% set statusClass = statusMap[statusName]|default('') %}

                <span class="status-badge {{ statusClass ? 'status-' ~ statusClass : '' }}">
                    <i class="bi bi-circle-fill status-icon"></i>
                    {{ statusName }}
                </span>
            {% endif %}

            {% if task.createdAt %}
                <span class="meta-pill">
                    <i class="bi bi-plus-circle"></i>
                    {{ task.createdAt|date('d F Y') }}
                </span>
            {% endif %}

            {% if task.lastChangedAt %}
                <span class="meta-pill">
                    <i class="bi bi-pencil"></i>
                    {{ task.lastChangedAt|date('d F Y') }}
                </span>
            {% endif %}
        </div>

        <div class="task-actions">

            {% if task.project.users.contains(app.user) %}
                <a href="{{ path('front_tasks_by_project', { id: task.project.id }) }}"
                   class="btn-glass btn-small">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            {% endif %}

            {% if task.project %}
                <a href="{{ path('front_project_show', {'id': task.project.id}) }}"
                   class="btn-glass btn-small">
                    <i class="bi bi-folder2-open"></i>
                    {{ task.project.name }}
                </a>
            {% endif %}

            {% if task.project.users.contains(app.user) %}
                <a href="{{ path('front_tasks_edit', {'id': task.id}) }}"
                   class="btn-glass btn-small">
                    <i class="bi bi-pencil"></i> Modifier
                </a>

                {{ include('front/tasks/_delete_form.html.twig', {
                    task: task,
                    btn_class: 'btn-glass-red btn-small'
                }) }}
            {% endif %}

        </div>
    </div>

    <div class="task-card mt-4">

        <div class="kanban-title-t">
            <i class="bi bi-clock-history"></i>
            Historique des modifications
        </div>

        {% if task.history is not empty %}
            <div class="task-meta">
                {% for entry in task.history %}
                    <span class="meta-pill">
                        <i class="bi bi-clock"></i>
                        {{ entry.updatedAt|date('d/m/Y H:i') }}
                        — {{ entry.changelog }}
                        {% if entry.author %}
                            ({{ entry.author.name }})
                        {% endif %}
                    </span>
                {% endfor %}
            </div>
        {% else %}
            <p class="task-description">
                Aucune modification enregistrée.
            </p>
        {% endif %}

    </div>

</div>

{% else %}
<div class="alert alert-danger mt-5">
    Accès refusé.
</div>
{% endif %}

{% endblock %}
