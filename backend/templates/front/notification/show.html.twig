{% extends 'base_front.html.twig' %}

{% block title %}Notification — Kuro{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Notification</h1>
            <p class="header-subtitle">Détails de la notification</p>
        </div>
        <div style="display:flex;gap:8px;">
            <a href="{{ path('app_notification_edit', {'id': notification.id}) }}" class="btn-glass">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
            <a href="{{ path('app_notification_index') }}" class="btn-reset">
                <i class="fa-solid fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>
</div>

<div class="task-card-form" style="max-width: 680px;">
    <div class="task-card-header">
        <h2 class="task-card-title">
            <i class="fa-solid fa-bell"></i>
            Informations
        </h2>
    </div>
    <div class="task-card-body">
        <div style="display:flex;flex-direction:column;gap:8px;">

            <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                    <i class="fa-solid fa-hashtag" style="color:var(--teal);"></i> ID
                </span>
                <span style="font-size:13px;color:var(--text-primary);font-weight:500;">{{ notification.id }}</span>
            </div>

            <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                    <i class="fa-solid fa-tag" style="color:var(--teal);"></i> Type
                </span>
                <span class="notif-type notif-type-{{ notification.type == 'task_assigned' ? 'assigned' : (notification.type == 'task_created' ? 'created' : 'updated') }}">
                    {{ notification.type }}
                </span>
            </div>

            <div style="padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                <div style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                    <i class="fa-solid fa-message" style="color:var(--teal);"></i> Message
                </div>
                <p style="font-size:13.5px;color:var(--text-primary);line-height:1.5;margin:0;">{{ notification.message }}</p>
            </div>

            {% if notification.link %}
            <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                    <i class="fa-solid fa-link" style="color:var(--teal);"></i> Lien
                </span>
                <a href="{{ notification.link }}" style="font-size:13px;color:var(--teal);font-weight:500;text-decoration:none;">
                    {{ notification.link }}
                </a>
            </div>
            {% endif %}

            <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                    <i class="fa-solid fa-eye" style="color:var(--teal);"></i> Lu
                </span>
                {% if notification.isRead %}
                    <span class="badge-terminee">Oui</span>
                {% else %}
                    <span class="badge-en-attente">Non</span>
                {% endif %}
            </div>

            <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                    <i class="fa-regular fa-clock" style="color:var(--teal);"></i> Créée le
                </span>
                <span style="font-size:13px;color:var(--text-primary);font-weight:500;">
                    {{ notification.createdAt ? notification.createdAt|date('d/m/Y à H:i') : '—' }}
                </span>
            </div>

        </div>
    </div>
    <div class="task-actions-footer">
        {{ include('notification/_delete_form.html.twig') }}
    </div>
</div>

{% endblock %}
