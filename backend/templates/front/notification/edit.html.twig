{% extends 'base_front.html.twig' %}

{% block title %}Modifier la notification{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Modifier la notification</h1>
        </div>
        <a href="{{ path('app_notification_index') }}" class="btn-reset">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="task-card-form" style="max-width: 680px;">
    <div class="task-card-header">
        <h2 class="task-card-title">
            <i class="fa-solid fa-bell"></i>
            Informations
        </h2>
    </div>
    <div class="task-card-body">
        {{ include('notification/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>
    <div class="task-actions-footer">
        {{ include('notification/_delete_form.html.twig') }}
    </div>
</div>

{% endblock %}
