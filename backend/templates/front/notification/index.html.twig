{% extends 'base_front.html.twig' %}

{% block title %}Mes notifications{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 page-title">
            <i class="fa-solid fa-bell me-2"></i>
            Mes notifications
        </h1>

        {% if notifications|filter(n => not n.isRead)|length > 0 %}
        <form method="post" action="{{ path('notifications_read_all') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('notif_read_all') }}">
            <button class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-check2-all"></i> Tout marquer comme lu
            </button>
        </form>
        {% endif %}
    </div>

    {% if notifications is empty %}
        <p class="text-muted">Aucune notification.</p>
    {% else %}
        <ul class="list-group">
        {% for n in notifications %}
            <li class="list-group-item d-flex justify-content-between align-items-start {{ not n.isRead ? 'list-group-item-light fw-semibold' : '' }}">
                <div>
                    <small class="text-muted me-2">{{ n.createdAt|date('d/m/Y H:i') }}</small>
                    {% if n.link %}
                        <a href="{{ n.link }}">{{ n.message }}</a>
                    {% else %}
                        {{ n.message }}
                    {% endif %}
                </div>
                {% if not n.isRead %}
                    <span class="badge bg-primary rounded-pill">Nouveau</span>
                {% endif %}
            </li>
        {% endfor %}
        </ul>
    {% endif %}

</div>
{% endblock %}
