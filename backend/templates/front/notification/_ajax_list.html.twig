{% if notifications is empty %}
    <div class="notif-empty">
        <i class="fa-solid fa-bell-slash" style="font-size:2rem;opacity:.2;display:block;margin-bottom:8px"></i>
        Aucune nouvelle notification.
    </div>
{% else %}
    <ul class="notif-list" style="list-style:none;padding:0;margin:0">
        {% for n in notifications %}
            <li class="notif-item {{ n.isRead ? 'read' : 'unread' }}" id="notif-{{ n.id }}">
                <div class="notif-header-line">
                    {% if n.type == 'task_assigned' %}
                        <span class="notif-type notif-type-assigned">📌 Assignée</span>
                    {% elseif n.type == 'task_created' %}
                        <span class="notif-type notif-type-created">🆕 Créée</span>
                    {% elseif n.type == 'task_updated' %}
                        <span class="notif-type notif-type-updated">✏️ Modifiée</span>
                    {% else %}
                        <span class="notif-type">🔔 Info</span>
                    {% endif %}
                    <small class="notif-date">{{ n.createdAt|date('d/m H:i') }}</small>
                </div>

                <p class="notif-message" style="margin:6px 0;font-size:13px;color:var(--text-secondary);line-height:1.4">
                    {% if n.link %}
                        <a href="{{ n.link }}" style="color:inherit;text-decoration:none">{{ n.message }}</a>
                    {% else %}
                        {{ n.message }}
                    {% endif %}
                </p>

                {% if not n.isRead %}
                    <button
                        class="notif-mark-read"
                        onclick="markRead({{ n.id }}, '{{ csrf_token('notif_read') }}')"
                        style="cursor:pointer;border:none;background:none;padding:0">
                        ✓ Marquer comme lu
                    </button>
                {% endif %}
            </li>
        {% endfor %}
    </ul>

    <script>
    function markRead(id, token) {
        fetch('/notification/' + id + '/read', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: '_token=' + encodeURIComponent(token)
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const item = document.getElementById('notif-' + id);
                if (item) {
                    item.classList.remove('unread');
                    item.classList.add('read');
                    const btn = item.querySelector('.notif-mark-read');
                    if (btn) btn.remove();
                }
            }
        })
        .catch(err => console.error('Erreur mark read:', err));
    }
    </script>
{% endif %}
