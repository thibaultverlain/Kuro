<form method="post" action="{{ path('app_notification_delete', {'id': notification.id}) }}"
      onsubmit="return confirm('Voulez-vous vraiment supprimer cette notification ?');"
      style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ notification.id) }}">
    <button type="submit" class="btn-glass btn-glass-red btn-small">
        <i class="fa-solid fa-trash"></i> Supprimer
    </button>
</form>
