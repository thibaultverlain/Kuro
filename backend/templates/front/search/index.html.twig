{% extends 'base_front.html.twig' %}

{% block title %}Recherche{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="page-header-modern mb-4">
        <div class="header-content">
            <div class="header-title-section">
                <h1 class="modern-title">
                    <i class="bi bi-search me-2"></i> Recherche & Filtres
                </h1>
                <p class="header-subtitle">Trouvez rapidement vos tâches</p>
            </div>
        </div>
    </div>

    {# Formulaire de recherche #}
    <div class="filters-wrapper mb-5">
        <form method="get" action="{{ path('front_search') }}">
            <div class="filters-grid">

                <div class="filter-item">
                    <label class="filter-label">
                        <i class="bi bi-search"></i> Mot-clé
                    </label>
                    <input type="text" name="q" class="form-control"
                           placeholder="Titre ou description..."
                           value="{{ query }}">
                </div>

                <div class="filter-item">
                    <label class="filter-label">
                        <i class="bi bi-check-circle"></i> Statut
                    </label>
                    <select name="status" class="form-select">
                        <option value="">Tous les statuts</option>
                        {% for s in ['En cours', 'En attente', 'Terminee', 'En retard'] %}
                            <option value="{{ s }}" {{ statusFilter == s ? 'selected' : '' }}>
                                {{ s }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-item">
                    <label class="filter-label">
                        <i class="bi bi-folder"></i> Projet
                    </label>
                    <select name="project" class="form-select">
                        <option value="">Tous les projets</option>
                        {% for p in projects %}
                            <option value="{{ p.id }}" {{ projectFilter == p.id|string ? 'selected' : '' }}>
                                {{ p.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

            </div>

            <div class="filters-actions mt-3">
                <button type="submit" class="btn-glass">
                    <i class="bi bi-search"></i> Rechercher
                </button>
                <a href="{{ path('front_search') }}" class="btn-reset ms-2">
                    <i class="bi bi-arrow-counterclockwise"></i> Réinitialiser
                </a>
            </div>
        </form>
    </div>

    {# Résultats #}
    {% if query != '' or statusFilter != '' or projectFilter != '' or userFilter != '' %}
        <h2 class="block-title mb-3">
            {{ tasks|length }} résultat{{ tasks|length > 1 ? 's' : '' }} trouvé{{ tasks|length > 1 ? 's' : '' }}
        </h2>

        {% if tasks is empty %}
            <p class="text-muted">Aucune tâche ne correspond à vos critères.</p>
        {% else %}
            <div class="kanban-board-t">
                {% for task in tasks %}
                    <div class="task-card">
                        <div class="task-header">
                            <div class="task-title-section">
                                <strong class="task-title">{{ task.title }}</strong>
                                {% if task.description %}
                                    <small class="task-description">{{ task.description }}</small>
                                {% endif %}
                            </div>
                            {% if task.dueDate %}
                                <span class="task-date">
                                    <i class="bi bi-calendar-event"></i>
                                    {{ task.dueDate|date('d/m/Y') }}
                                </span>
                            {% endif %}
                        </div>

                        <div class="task-meta">
                            {% if task.project %}
                                <span class="meta-pill">
                                    <i class="bi bi-folder2-open"></i>
                                    {{ task.project.name }}
                                </span>
                            {% endif %}

                            {% if task.status %}
                                {% set statusName = task.status.name %}
                                {% set statusMap = {
                                    'En cours': 'en-cours',
                                    'Terminee': 'termine',
                                    'En retard': 'retard',
                                    'En attente': 'en-attente'
                                } %}
                                {% set statusClass = statusMap[statusName]|default('') %}
                                <span class="status-badge {{ statusClass ? 'status-' ~ statusClass : '' }}">
                                    <i class="bi bi-circle-fill status-icon"></i>
                                    {{ statusName }}
                                </span>
                            {% endif %}

                            {% if task.priority %}
                                {% set priorityName = task.priority.name %}
                                {% set priorityMap = {
                                    'Tres faible': 'tres-faible',
                                    'Faible': 'faible',
                                    'Modere': 'modere',
                                    'Eleve': 'eleve',
                                    'Tres eleve': 'tres-eleve'
                                } %}
                                {% set priorityClass = priorityMap[priorityName]|default('') %}
                                <span class="priority-badge {{ priorityClass ? 'priority-' ~ priorityClass : '' }}">
                                    <i class="bi bi-flag-fill"></i>
                                    {{ priorityName }}
                                </span>
                            {% endif %}

                            {% if task.users is not empty %}
                                <span class="meta-pill">
                                    <i class="bi bi-person"></i>
                                    {% for u in task.users %}{{ u.name }}{% if not loop.last %}, {% endif %}{% endfor %}
                                </span>
                            {% endif %}
                        </div>

                        <div class="task-actions">
                            <a href="{{ path('front_tasks_show', {'id': task.id}) }}" class="btn-glass btn-small">
                                <i class="bi bi-eye"></i> Voir
                            </a>
                            <a href="{{ path('front_tasks_edit', {'id': task.id}) }}" class="btn-glass btn-small">
                                <i class="bi bi-pencil"></i> Modifier
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    {% endif %}

</div>
{% endblock %}
