{% extends 'base_admin.html.twig' %}

{% block title %}Modifier le projet{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Modifier le projet</h1>
            <p class="header-subtitle">{{ project.name }}</p>
        </div>
        <a href="{{ path('admin_project_index') }}" class="btn-reset">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="task-card-form" style="max-width: 680px;">
    <div class="task-card-header">
        <h2 class="task-card-title">
            <i class="fa-solid fa-folder-pen"></i>
            Informations du projet
        </h2>
    </div>
    <div class="task-card-body">
        {{ include('admin/project/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>
    <div class="task-actions-footer">
        {{ include('admin/project/_delete_form.html.twig') }}
    </div>
</div>

{% endblock %}
