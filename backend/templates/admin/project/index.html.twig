{% extends 'base_front.html.twig' %}

{% block title %}Liste des projets{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Projets</h1>
            <p class="header-subtitle">{{ projects|length }} projet{{ projects|length > 1 ? 's' : '' }}</p>
        </div>
        <a href="{{ path('admin_project_new') }}" class="btn-glass">
            <i class="fa-solid fa-plus"></i> Nouveau projet
        </a>
    </div>
</div>

<div class="users-table-wrapper">
    <div class="table-responsive">
        <table class="modern-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Créé le</th>
                    <th>Tâches</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for project in projects %}
                    <tr>
                        <td><span class="id-badge">{{ project.id }}</span></td>
                        <td>
                            <span style="font-weight:600;color:var(--text-primary);">{{ project.name }}</span>
                        </td>
                        <td>
                            <span style="color:var(--text-secondary);font-size:12px;">
                                {{ project.description|slice(0, 60) }}{% if project.description|length > 60 %}…{% endif %}
                            </span>
                        </td>
                        <td>
                            <span class="date-text">
                                <i class="fa-regular fa-calendar"></i>
                                {{ project.createdAt ? project.createdAt|date('d/m/Y') : '—' }}
                            </span>
                        </td>
                        <td>
                            {% if project.tasks is not empty %}
                                <span class="meta-pill">
                                    <i class="fa-solid fa-list-check"></i>
                                    {{ project.tasks|length }} tâche{{ project.tasks|length > 1 ? 's' : '' }}
                                </span>
                            {% else %}
                                <span style="color:var(--text-muted);font-size:12px;">Aucune tâche</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a href="{{ path('admin_project_show', {'id': project.id}) }}" class="btn-action btn-view" title="Voir">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_project_edit', {'id': project.id}) }}" class="btn-action btn-edit" title="Modifier">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                {{ include('admin/project/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;color:var(--text-muted);padding:2rem;font-size:13px;">
                            Aucun projet trouvé
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
