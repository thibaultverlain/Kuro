{% extends 'base_admin.html.twig' %}

{% block title %}Détails du projet{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">{{ project.name }}</h1>
            <p class="header-subtitle">Détails du projet</p>
        </div>
        <div style="display:flex;gap:8px;">
            <a href="{{ path('admin_project_edit', {'id': project.id}) }}" class="btn-glass">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
            <a href="{{ path('admin_project_index') }}" class="btn-reset">
                <i class="fa-solid fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>
</div>

<div class="row g-3">

    {# Infos principales #}
    <div class="col-md-7">
        <div class="task-card-form">
            <div class="task-card-header">
                <h2 class="task-card-title">
                    <i class="fa-solid fa-folder-open"></i>
                    Informations
                </h2>
            </div>
            <div class="task-card-body">
                <div style="display:flex;flex-direction:column;gap:8px;">

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-hashtag" style="color:var(--teal);"></i> ID
                        </span>
                        <span class="id-badge">{{ project.id }}</span>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-folder" style="color:var(--teal);"></i> Nom
                        </span>
                        <span style="font-size:13px;color:var(--text-primary);font-weight:600;">{{ project.name }}</span>
                    </div>

                    <div style="padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <div style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                            <i class="fa-solid fa-align-left" style="color:var(--teal);"></i> Description
                        </div>
                        <p style="font-size:13px;color:var(--text-primary);line-height:1.6;margin:0;">
                            {{ project.description ?: '—' }}
                        </p>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-regular fa-calendar" style="color:var(--teal);"></i> Créé le
                        </span>
                        <span class="date-text">
                            {{ project.createdAt ? project.createdAt|date('d/m/Y') : '—' }}
                        </span>
                    </div>

                </div>
            </div>
            <div class="task-actions-footer">
                {{ include('admin/project/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

    {# Tâches #}
    <div class="col-md-5">
        <div class="dashboard-block h-100">
            <h2 class="block-title">
                Tâches
                <span class="meta-pill" style="margin-left:auto;">{{ project.tasks|length }}</span>
            </h2>
            {% if project.tasks is not empty %}
                <div style="display:flex;flex-direction:column;gap:6px;">
                    {% for task in project.tasks %}
                        <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 12px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                            <span style="font-size:13px;color:var(--text-primary);font-weight:500;">{{ task.title }}</span>
                            {% if task.dueDate %}
                                <span class="task-date">
                                    <i class="fa-regular fa-calendar"></i>
                                    {{ task.dueDate|date('d/m/Y') }}
                                </span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state-text">
                    <i class="fa-solid fa-inbox"></i>
                    Aucune tâche
                </div>
            {% endif %}
        </div>
    </div>

</div>

{% endblock %}
