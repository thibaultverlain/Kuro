<form method="post" action="{{ path('admin_priority_delete', {'id': priority.id}) }}"
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');"
      style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ priority.id) }}">
    <button type="submit" class="btn-glass btn-glass-red btn-small">
        <i class="fa-solid fa-trash"></i> Supprimer
    </button>
</form>
