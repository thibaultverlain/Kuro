{% extends 'base_admin.html.twig' %}

{% block title %}Nouvelle priorité{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Nouvelle priorité</h1>
        </div>
        <a href="{{ path('admin_priority_index') }}" class="btn-reset">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="task-card-form" style="max-width: 680px;">
