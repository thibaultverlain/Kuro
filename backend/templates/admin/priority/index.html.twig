{% extends 'base_admin.html.twig' %}

{% block title %}Liste des priorités{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Priorités</h1>
            <p class="header-subtitle">{{ priorities|length }} priorité{{ priorities|length > 1 ? 's' : '' }}</p>
        </div>
        <a href="{{ path('admin_priority_new') }}" class="btn-glass">
            <i class="fa-solid fa-plus"></i> Nouvelle priorité
        </a>
    </div>
</div>

<div class="users-table-wrapper">
    <div class="table-responsive">
        <table class="modern-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for priority in priorities %}
                    <tr>
                        <td>
                            <span class="id-badge">{{ priority.id }}</span>
                        </td>
                        <td>
                            {% set priorityMap = {
                                'Tres faible': 'tres-faible',
                                'Faible': 'faible',
                                'Modere': 'modere',
                                'Eleve': 'eleve',
                                'Tres eleve': 'tres-eleve'
                            } %}
                            {% set priorityClass = priorityMap[priority.name]|default('') %}
                            <span class="priority-badge priority-{{ priorityClass }}">
                                <i class="fa-solid fa-flag"></i>
                                {{ priority.name }}
                            </span>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a href="{{ path('admin_priority_show', {'id': priority.id}) }}" class="btn-action btn-view" title="Voir">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_priority_edit', {'id': priority.id}) }}" class="btn-action btn-edit" title="Modifier">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" style="text-align:center;color:var(--text-muted);padding:2rem;font-size:13px;">
                            Aucune priorité trouvée
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
