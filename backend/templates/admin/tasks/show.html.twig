{% extends 'base_admin.html.twig' %}

{% block title %}Détails de la tâche{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">{{ task.title }}</h1>
            <p class="header-subtitle">Détails de la tâche</p>
        </div>
        <div style="display:flex;gap:8px;">
            <a href="{{ path('admin_tasks_edit', {'id': task.id}) }}" class="btn-glass">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
            <a href="{{ path('admin_tasks_index') }}" class="btn-reset">
                <i class="fa-solid fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>
</div>

<div class="row g-3">

    <div class="col-md-8">
        <div class="task-card-form">
            <div class="task-card-header">
                <h2 class="task-card-title">
                    <i class="fa-solid fa-circle-info"></i>
                    Informations
                </h2>
            </div>
            <div class="task-card-body">
                <div style="display:flex;flex-direction:column;gap:8px;">

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-hashtag" style="color:var(--teal);"></i> ID
                        </span>
                        <span class="id-badge">{{ task.id }}</span>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-heading" style="color:var(--teal);"></i> Titre
                        </span>
                        <span style="font-size:13px;color:var(--text-primary);font-weight:600;">{{ task.title }}</span>
                    </div>

                    {% if task.description %}
                    <div style="padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <div style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                            <i class="fa-solid fa-align-left" style="color:var(--teal);"></i> Description
                        </div>
                        <p style="font-size:13px;color:var(--text-primary);line-height:1.6;margin:0;">{{ task.description }}</p>
                    </div>
                    {% endif %}

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-regular fa-calendar" style="color:var(--teal);"></i> Échéance
                        </span>
                        <span style="font-size:13px;color:var(--text-primary);">
                            {{ task.dueDate ? task.dueDate|date('d/m/Y') : '—' }}
                        </span>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-plus" style="color:var(--teal);"></i> Créée le
                        </span>
                        <span class="date-text">{{ task.createdAt ? task.createdAt|date('d/m/Y') : '—' }}</span>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-pen" style="color:var(--teal);"></i> Dernière modification
                        </span>
                        <span class="date-text">{{ task.lastChangedAt ? task.lastChangedAt|date('d/m/Y') : '—' }}</span>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-flag" style="color:var(--teal);"></i> Priorité
                        </span>
                        {% if task.priority %}
                            {% set priorityMap = {
                                'Tres faible': 'tres-faible',
                                'Faible': 'faible',
                                'Modere': 'modere',
                                'Eleve': 'eleve',
                                'Tres eleve': 'tres-eleve'
                            } %}
                            {% set priorityClass = priorityMap[task.priority.name]|default('') %}
                            <span class="priority-badge priority-{{ priorityClass }}">
                                <i class="fa-solid fa-flag"></i>
                                {{ task.priority.name }}
                            </span>
                        {% else %}
                            <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-circle-half-stroke" style="color:var(--teal);"></i> Statut
                        </span>
                        {% if task.status %}
                            {% set statusMap = {
                                'En cours':  'en-cours',
                                'Terminée':  'termine',
                                'En retard': 'retard',
                                'À faire':   'en-attente'
                            } %}
                            {% set statusClass = statusMap[task.status.name]|default('') %}
                            <span class="status-badge status-{{ statusClass }}">
                                <i class="fa-solid fa-circle status-icon"></i>
                                {{ task.status.name }}
                            </span>
                        {% else %}
                            <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <span style="font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-folder-open" style="color:var(--teal);"></i> Projet
                        </span>
                        {% if task.project %}
                            <a href="{{ path('admin_project_show', {'id': task.project.id}) }}"
                               style="font-size:13px;color:var(--teal);font-weight:500;text-decoration:none;">
                                {{ task.project.name }}
                            </a>
                        {% else %}
                            <span style="color:var(--text-muted);">—</span>
                        {% endif %}
                    </div>

                </div>
            </div>
            <div class="task-actions-footer">
                {{ include('admin/tasks/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

    {# Assignés #}
    {% if task.users is not empty %}
    <div class="col-md-4">
        <div class="dashboard-block">
            <h2 class="block-title">Assignés</h2>
            <div style="display:flex;flex-direction:column;gap:6px;">
                {% for user in task.users %}
                    <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--bg-elevated);border:1px solid var(--border-subtle);border-radius:var(--r-md);">
                        <div style="width:30px;height:30px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;color:var(--bg-root);font-size:12px;font-weight:700;flex-shrink:0;">
                            {{ user.name|slice(0,1)|upper }}
                        </div>
                        <span style="font-size:13px;color:var(--text-primary);font-weight:500;">{{ user.name }}</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

</div>

{% endblock %}
