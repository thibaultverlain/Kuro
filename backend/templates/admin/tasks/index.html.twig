{% extends 'base_admin.html.twig' %}

{% block title %}Tâches — Admin Kuro{% endblock %}

{% block body %}

<div class="page-header-modern mb-4">
    <div class="header-content">
        <div class="header-title-section">
            <h1 class="modern-title">Gestion des tâches</h1>
            <p class="header-subtitle">{{ tasks|length }} tâche{{ tasks|length > 1 ? 's' : '' }} au total</p>
        </div>
        <div style="display:flex;gap:8px;">
            <a href="{{ path('admin_tasks_new') }}" class="btn-glass">
                <i class="fa-solid fa-plus"></i> Nouvelle tâche
            </a>
            <a href="{{ path('front_project_index') }}" class="btn-reset">
                <i class="fa-solid fa-folder-open"></i> Via les projets
            </a>
        </div>
    </div>
</div>

{% if tasks is empty %}
    <div class="dashboard-block" style="text-align:center;padding:3rem;">
        <i class="fa-solid fa-list-check" style="font-size:3rem;opacity:.2;display:block;margin-bottom:1rem;color:var(--text-muted);"></i>
        <p style="color:var(--text-muted);font-size:13px;">Aucune tâche trouvée.</p>
    </div>
{% else %}
    <div class="users-table-wrapper">
        <div class="table-responsive">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Titre</th>
                        <th>Projet</th>
                        <th>Statut</th>
                        <th>Priorité</th>
                        <th>Échéance</th>
                        <th>Créée le</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for task in tasks %}
                        <tr>
                            <td><span class="id-badge">{{ task.id }}</span></td>
                            <td>
                                <span style="font-weight:600;color:var(--text-primary);font-size:13px;">{{ task.title }}</span>
                            </td>
                            <td>
                                {% if task.project %}
                                    <a href="{{ path('admin_project_show', {'id': task.project.id}) }}"
                                       style="color:var(--teal);text-decoration:none;font-size:13px;font-weight:500;">
                                        {{ task.project.name }}
                                    </a>
                                {% else %}
                                    <span style="color:var(--text-muted);">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if task.status %}
                                    {% set statusMap = {
                                        'En cours':  'en-cours',
                                        'Terminée':  'termine',
                                        'En retard': 'retard',
                                        'À faire':   'en-attente'
                                    } %}
                                    {% set statusClass = statusMap[task.status.name]|default('') %}
                                    <span class="status-badge status-{{ statusClass }}">
                                        <i class="fa-solid fa-circle status-icon"></i>
                                        {{ task.status.name }}
                                    </span>
                                {% else %}
                                    <span style="color:var(--text-muted);">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if task.priority %}
                                    {% set priorityMap = {
                                        'Tres faible': 'tres-faible',
                                        'Faible': 'faible',
                                        'Modere': 'modere',
                                        'Eleve': 'eleve',
                                        'Tres eleve': 'tres-eleve'
                                    } %}
                                    {% set priorityClass = priorityMap[task.priority.name]|default('') %}
                                    <span class="priority-badge priority-{{ priorityClass }}">
                                        <i class="fa-solid fa-flag"></i>
                                        {{ task.priority.name }}
                                    </span>
                                {% else %}
                                    <span style="color:var(--text-muted);">—</span>
                                {% endif %}
                            </td>
                            <td><span class="date-text">{{ task.dueDate ? task.dueDate|date('d/m/Y') : '—' }}</span></td>
                            <td><span class="date-text">{{ task.createdAt ? task.createdAt|date('d/m/Y') : '—' }}</span></td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('admin_tasks_show', {'id': task.id}) }}" class="btn-action btn-view" title="Voir">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a href="{{ path('admin_tasks_edit', {'id': task.id}) }}" class="btn-action btn-edit" title="Modifier">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    {{ include('admin/tasks/_delete_form.html.twig') }}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}

{% endblock %}
