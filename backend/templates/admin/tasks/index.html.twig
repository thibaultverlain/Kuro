{% extends 'base_admin.html.twig' %}

{% block title %}Tâches — Admin Kuro{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fa-solid fa-list-check me-2" style="color:#a855f7"></i>Gestion des tâches</h1>
    <a href="{{ path('front_project_index') }}" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i> Créer via les projets
    </a>
</div>

{% if tasks is empty %}
    <div style="text-align:center;padding:3rem;color:#5e5a7a">
        <i class="fa-solid fa-list-check" style="font-size:3rem;opacity:.2;display:block;margin-bottom:1rem"></i>
        Aucune tâche trouvée.
    </div>
{% else %}
    <div style="overflow-x:auto">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Titre</th>
                    <th>Projet</th>
                    <th>Statut</th>
                    <th>Priorité</th>
                    <th>Échéance</th>
                    <th>Créée le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for task in tasks %}
                <tr>
                    <td><span style="color:#5e5a7a;font-size:12px">#{{ task.id }}</span></td>
                    <td><strong>{{ task.title }}</strong></td>
                    <td>
                        {% if task.project %}
                            <a href="{{ path('admin_project_show', {'id': task.project.id}) }}"
                               style="color:#a855f7;text-decoration:none">
                                {{ task.project.name }}
                            </a>
                        {% endif %}
                    </td>
                    <td>
                        {% if task.status %}
                            <span style="padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;
                                background:rgba(6,214,255,0.1);color:#06d6ff;border:1px solid rgba(6,214,255,0.2)">
                                {{ task.status.name }}
                            </span>
                        {% endif %}
                    </td>
                    <td>
                        {% if task.priority %}
                            <span style="padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;
                                background:rgba(124,58,255,0.1);color:#a855f7;border:1px solid rgba(124,58,255,0.2)">
                                {{ task.priority.name }}
                            </span>
                        {% endif %}
                    </td>
                    <td style="font-size:12px;color:#9d98c0">
                        {{ task.dueDate ? task.dueDate|date('d/m/Y') : '—' }}
                    </td>
                    <td style="font-size:12px;color:#9d98c0">
                        {{ task.createdAt ? task.createdAt|date('d/m/Y') : '—' }}
                    </td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <a href="{{ path('admin_tasks_show', {'id': task.id}) }}"
                               class="btn btn-sm btn-secondary">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a href="{{ path('admin_tasks_edit', {'id': task.id}) }}"
                               class="btn btn-sm btn-primary">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            {{ include('admin/tasks/_delete_form.html.twig') }}
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
