<form method="post" action="{{ path('admin_role_delete', {'id': role.id}) }}"
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce rôle ?');"
      style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ role.id) }}">
    <button type="submit" class="btn-glass btn-glass-red btn-small">
        <i class="fa-solid fa-trash"></i> Supprimer
    </button>
</form>
